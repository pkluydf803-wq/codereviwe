rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: webhooks
    // Document ID: auto-generated
    // Fields:
    //   - code: string (required)
    //   - language: string (required)
    //   - title: string (required)
    //   - timestamp: string (required, format: date-time)
    //   - status: string (required, enum: ['pending', 'reviewed'])
    //   - result: map (optional, ReviewResult)
    //
    // Collection: reviews
    // Document ID: auto-generated
    // Fields:
    //   - code: string (required)
    //   - language: string (required)
    //   - timestamp: string (required, format: date-time)
    //   - result: map (required, ReviewResult)
    //   - toolName: string (optional)
    //   - userId: string (optional)
    //
    // Collection: submissions
    // Document ID: auto-generated
    // Fields:
    //   - challengeId: string (required)
    //   - userId: string (required)
    //   - code: string (required)
    //   - status: string (required, enum: ['Passed', 'Failed'])
    //   - timestamp: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "chgowthaman73@gmail.com" && request.auth.token.email_verified == true));
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidReviewResult(result) {
      return result is map &&
        result.keys().hasAll(['bugs', 'fixedCode', 'explanation']) &&
        result.bugs is list &&
        result.fixedCode is string &&
        result.explanation is string;
    }

    function isValidWebhook(data) {
      return data.keys().hasAll(['code', 'language', 'title', 'timestamp', 'status']) &&
        data.code is string && data.code.size() > 0 &&
        data.language is string &&
        data.title is string &&
        data.timestamp is string &&
        data.status in ['pending', 'reviewed'];
    }

    function isValidReview(data) {
      return data.keys().hasAll(['code', 'language', 'timestamp', 'result']) &&
        data.code is string &&
        data.language is string &&
        data.timestamp is string &&
        isValidReviewResult(data.result);
    }

    function isValidSubmission(data) {
      return data.keys().hasAll(['challengeId', 'userId', 'code', 'status', 'timestamp']) &&
        data.challengeId is string &&
        data.userId == request.auth.uid &&
        data.code is string &&
        data.status in ['Passed', 'Failed'] &&
        data.timestamp is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
    }

    match /webhooks/{webhookId} {
      // Webhooks are created by the server (admin) or potentially by users if they have a token
      // For this app, we'll allow admins to read/write all webhooks
      // And authenticated users to read them (for dashboard)
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /reviews/{reviewId} {
      // Reviews can be created by authenticated users
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidReview(request.resource.data);
      allow update: if isAdmin();
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }

    match /submissions/{submissionId} {
      // Submissions are created by authenticated users for their own challenges
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidSubmission(request.resource.data);
      allow update: if isAdmin();
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }
  }
}
